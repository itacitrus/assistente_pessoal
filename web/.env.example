# URL base da API REST do bot Go (o cliente prepende isto a /api/v1/...).
#
# Dev local:  http://localhost:8080            -> http://localhost:8080/api/v1/me
# Producao:   https://api.itacitrus.com.br/assistente
#             -> https://api.itacitrus.com.br/assistente/api/v1/me
#
# Em prod o ALB compartilhado so roteia /assistente/* pra instancia do bot,
# por isso a API e montada sob esse prefixo (API_PATH_PREFIX=/assistente no
# .env do bot). O frontend deve viver num subdominio de itacitrus.com.br
# (ex: assistente.itacitrus.com.br) pra o cookie de sessao (SameSite) fluir.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
